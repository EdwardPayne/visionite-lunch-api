# Copy to .env and adjust for local dev. .env is gitignored.

# Network
PORT=4010
HOST=127.0.0.1

# Comma-separated list of origins your frontend(s) run on. Cookies require
# credentials: true + a specific origin (no wildcards).
TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth — generate a real secret with: openssl rand -base64 32
# In production this MUST be set; the dev fallback is rejected when NODE_ENV=production.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4010

# Optional: override the SQLite file location (default: ./data/auth.db)
# AUTH_DB_PATH=./data/auth.db

# Optional: override the persisted scrape-cache location.
# Default: ./data/cache-<scraperId>.json. Delete to force a fresh scrape on boot.
# CACHE_PERSIST_PATH=./data/cache-matochmat-ostersund.json
